# ================================
# NewsHive Pro — Environment Variables
# Copy this to .env.local and fill in your values
# ================================

# Supabase (your existing project)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Groq AI (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key

# NewsAPI (free at newsapi.org — 100 req/day)
NEWS_API_KEY=your_newsapi_key

# Cloudinary (your existing account)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Resend (free at resend.com — 3000 emails/month)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=newsletter@yourdomain.com

# App URL (change in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
